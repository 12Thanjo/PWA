import DOM;


local textarea = DOM("#textarea");

local fontsize = Math.floor( 9  /100*window.innerHeight);
textarea.style("fontSize", fontsize);

// textarea.on("touchend", @()->{
	// textarea.focus();
// });

resize_textarea = function(){
	textarea.style('height', 5);
	textarea.style('height', textarea.element.scrollHeight - 20);
	console.log("hi");
};
resize_textarea();




// buttons /////////////////////////////////////////////////
DOM("#up").on("click", @()->{
	fontsize += 5;
	textarea.style("fontSize", fontsize);
	resize_textarea();
});


DOM("#down").on("click", @()->{
	fontsize -= 5;
	textarea.style("fontSize", fontsize);
	resize_textarea();
});

DOM("#clear").on("click", @()->{
	textarea.value = "";
	resize_textarea();
});
DOM("#reload").on('click', @()->{
	location.reload();
});

DOM("#date").innerHTML += Date.now() + " <  Don't worry about this, Olivia :)";